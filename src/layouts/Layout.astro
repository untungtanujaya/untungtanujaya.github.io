---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  activeTab?: 'home' | 'resume' | 'projects' | 'articles' | 'apps';
}

const { 
  title = "Untung Tanujaya | Software Engineer", 
  description = "Software Engineer specializing in high-performance backends and clean architectures.",
  activeTab = "home"
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    
    <!-- SEO Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Untung Tanujaya" />
    <meta name="keywords" content="Untung Tanujaya, Software Engineer, Go, React, Astro, Backend Developer, Portfolio" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    
    <!-- Google Fonts Preconnect and Link -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400&display=swap" rel="stylesheet">
  </head>
  <body>
    <!-- Responsive Header Navigation -->
    <header class="glass-nav">
      <nav class="nav-content">
        <a href="/" class="logo" aria-label="Untung Tanujaya Home">
          <img src="/logo-ut.webp" alt="UT Logo" class="logo-icon" width="70" height="32" />
        </a>
        <button class="menu-toggle" id="menu-toggle" aria-label="Toggle Menu" aria-expanded="false">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="4" y1="12" x2="20" y2="12"></line>
            <line x1="4" y1="6" x2="20" y2="6"></line>
            <line x1="4" y1="18" x2="20" y2="18"></line>
          </svg>
        </button>
        <div class="nav-links">
          <a href="/" class={activeTab === 'home' ? 'active' : ''}>Home</a>
          <a href="/resume" class={activeTab === 'resume' ? 'active' : ''}>Resume</a>
          <a href="/projects" class={activeTab === 'projects' ? 'active' : ''}>Projects</a>
          <a href="/articles" class={activeTab === 'articles' ? 'active' : ''}>Articles</a>
          <a href="/apps" class={activeTab === 'apps' ? 'active' : ''}>Apps</a>
        </div>
      </nav>
    </header>

    <!-- Main Content Container -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer>
      <div class="footer-content">
        <p>&copy; {new Date().getFullYear()} Untung Tanujaya. Built with Astro (SSG).</p>
        <p style="font-size: 0.8rem; color: var(--text-secondary);">
          Looking for clinical utilities? Visit the <a href="/apps" style="color: var(--accent-teal); text-decoration: underline;">Clinical Apps Suite</a>.
        </p>
      </div>
    </footer>

    <!-- Mobile Menu script -->
    <script is:inline>
      const menuToggle = document.getElementById('menu-toggle');
      const navLinks = document.querySelector('.nav-links');
      if (menuToggle && navLinks) {
        menuToggle.addEventListener('click', () => {
          const isExpanded = menuToggle.getAttribute('aria-expanded') === 'true';
          menuToggle.setAttribute('aria-expanded', !isExpanded);
          navLinks.classList.toggle('active');
        });
      }
    </script>
  </body>
</html>
