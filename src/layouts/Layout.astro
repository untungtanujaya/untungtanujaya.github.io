---
import '../styles/global.css';
import '@fontsource-variable/plus-jakarta-sans';
import '@fontsource-variable/plus-jakarta-sans/wght-italic.css';
import normalFont from '@fontsource-variable/plus-jakarta-sans/files/plus-jakarta-sans-latin-wght-normal.woff2?url';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
  activeTab?: 'home' | 'resume' | 'projects' | 'articles' | 'apps';
}

const {
  title = "Untung Tanujaya | Software Engineer",
  description = "Software Engineer specializing in high-performance backends and clean architectures.",
  activeTab = "home"
} = Astro.props;

// Motion System kill-switch — see docs/adr/0001-motion-system-zero-regression.md
const MOTION = { pageTransitions: true };

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL('/untung-tanujaya.webp', Astro.site);
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preload" href={normalFont} as="font" type="font/woff2" crossorigin />
    <meta name="theme-color" content="#07090d" />
    <meta name="color-scheme" content="dark" />
    {MOTION.pageTransitions && <ClientRouter />}

    <!-- Motion gate: add .motion-ok ONLY when the user has no reduced-motion
         preference. Without this class, all motion start-states stay inert and
         content renders fully visible (reduced-motion = off total, no-JS safe).
         Failsafe: if the motion module fails to load/run, .motion-off is added
         after 2.5s and every start-state is released (content stays visible). -->
    <script is:inline>
      if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        document.documentElement.classList.add('motion-ok');
        window.clearTimeout(window.__motionFailsafe);
        window.__motionFailsafe = window.setTimeout(function () {
          document.documentElement.classList.add('motion-off');
        }, 2500);
      }
    </script>
    
    <!-- SEO Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Untung Tanujaya" />
    <meta name="keywords" content="Untung Tanujaya, Software Engineer, Go, React, Astro, Backend Developer, Portfolio" />

    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Untung Tanujaya" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body>
    <a class="skip-link" href="#content">Skip to content</a>

    <header class="glass-nav">
      <nav class="nav-content">
        <a href="/" class="logo" aria-label="Untung Tanujaya Home">
          <img src="/logo-ut.webp" alt="UT Logo" class="logo-icon" width="70" height="32" />
        </a>
        <button class="menu-toggle" id="menu-toggle" aria-label="Toggle navigation" aria-expanded="false" aria-controls="site-menu">
          <span aria-hidden="true"></span>
          <span aria-hidden="true"></span>
          <span aria-hidden="true"></span>
        </button>
        <div class="nav-links" id="site-menu">
          <a href="/" class={activeTab === 'home' ? 'active' : ''}>Home</a>
          <a href="/resume/" class={activeTab === 'resume' ? 'active' : ''}>Resume</a>
          <a href="/projects/" class={activeTab === 'projects' ? 'active' : ''}>Projects</a>
          <a href="/articles/" class={activeTab === 'articles' ? 'active' : ''}>Articles</a>
          <a href="/apps/" class={activeTab === 'apps' ? 'active' : ''}>Apps</a>
        </div>
      </nav>
    </header>

    <main id="content">
      <slot />
    </main>

    <footer>
      <div class="footer-content">
        <p>&copy; {new Date().getFullYear()} Untung Tanujaya. Built with Astro.</p>
        <div class="footer-links" aria-label="Footer links">
          <a href="mailto:utanujaya@gmail.com">Email</a>
          <a href="https://github.com/untungtanujaya" target="_blank" rel="noopener noreferrer">GitHub</a>
          <a href="https://linkedin.com/in/tanujaya" target="_blank" rel="noopener noreferrer">LinkedIn</a>
        </div>
      </div>
    </footer>

    <script is:inline>
      // Event delegation on `document` — survives ClientRouter body swaps
      // (document itself is never swapped). Per-element listeners would die
      // with the old DOM and is:inline scripts are not re-executed by the
      // router, so delegation + idempotent registration is the robust pattern.
      if (!window.__menuDelegated) {
        window.__menuDelegated = true;
        document.addEventListener('click', (e) => {
          const toggle = e.target.closest('#menu-toggle');
          if (toggle) {
            const navLinks = document.getElementById('site-menu');
            if (!navLinks) return;
            const isExpanded = toggle.getAttribute('aria-expanded') === 'true';
            toggle.setAttribute('aria-expanded', String(!isExpanded));
            navLinks.classList.toggle('active', !isExpanded);
            return;
          }
          if (e.target.closest('#site-menu a')) {
            const toggle = document.getElementById('menu-toggle');
            const navLinks = document.getElementById('site-menu');
            if (toggle) toggle.setAttribute('aria-expanded', 'false');
            if (navLinks) navLinks.classList.remove('active');
          }
        });
      }
    </script>
    <script>
      import '../scripts/motion';
    </script>
  </body>
</html>
