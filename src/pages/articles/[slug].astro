---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map((art) => ({
    params: { slug: art.slug || art.data.slug || art.id },
    props: { art },
  }));
}

const { art } = Astro.props;
const { Content } = await render(art);

---

<Layout title={`${art.data.title} | Articles`} activeTab="articles">
  <div class="bento-grid">
    <article class="bento-card span-12">
      <div class="article-header">
        <a href="/articles" class="back-link">&larr; Back to Articles</a>
        <div style="margin-top: 1rem;">
          <span class="badge badge-fern">{art.data.subtitle}</span>
          <h1 class="article-title">{art.data.title}</h1>
          <div class="article-meta">
            <span>Untung Tanujaya</span>
            <span>•</span>
            <span>{art.data.read_time} min read</span>
          </div>
        </div>
      </div>
      
      <div class="article-body">
        <Content />
      </div>
    </article>
  </div>
</Layout>
